{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyRemoteTouch",
  "version": "0.0.1",
  "identifier": "com.l0101.myremotetouch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MyRemoteTouch",
        "width": 540,
        "height": 980,
        "minWidth": 540,
        "minHeight": 980,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: http://localhost:9100; connect-src 'self' http://localhost:9100"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}