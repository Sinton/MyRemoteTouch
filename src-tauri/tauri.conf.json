{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "my-remote-touch",
  "version": "0.1.0",
  "identifier": "com.yan.my-remote-touch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "my-remote-touch",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: http://localhost:9100; connect-src 'self' http://localhost:8100 http://localhost:9100"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}